{
  "productName": "Heario",
  "version": "0.1.1",
  "identifier": "software.heario.app",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm --prefix C:/Users/jacko/heario-app/ui run dev",
    "beforeBuildCommand": "npm --prefix C:/Users/jacko/heario-app/ui run build"
  },
  "app": {
    "windows": [
      {
        "title": "Heario",
        "width": 580,
        "height": 400,
        "resizable": true,
        "decorations": false,
        "alwaysOnTop": true,
        "transparent": true,
        "shadow": true,
        "skipTaskbar": false,
        "x": 40,
        "y": 40
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/icon.ico"],
    "resources": {
      "../sidecar/dist/heario-sidecar.exe": "./"
    }
  }
}
